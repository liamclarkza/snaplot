{
  "name": "snaplot",
  "version": "0.1.0",
  "type": "module",
  "description": "High-performance canvas chart library for SolidJS",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "solid-js": "^1.9.5",
    "vite": "^7.0.0",
    "vite-plugin-solid": "^2.11.0",
    "vite-plugin-dts": "^4.5.0",
    "typescript": "^5.7.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liamclarkza/snaplot.git"
  },
  "license": "MIT",
  "keywords": [
    "solidjs",
    "chart",
    "canvas",
    "visualization",
    "dashboard",
    "heatmap",
    "scatter",
    "histogram"
  ]
}
