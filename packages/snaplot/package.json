{
  "name": "snaplot",
  "version": "0.9.0",
  "type": "module",
  "description": "High-performance charts that actually look good",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core.js",
      "types": "./dist/core.d.ts"
    },
    "./solid": {
      "import": "./dist/solid.js",
      "types": "./dist/solid.d.ts"
    },
    "./legend-table.css": {
      "import": "./dist/legend-table.css",
      "default": "./dist/legend-table.css"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css",
    "dist/*.css"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0"
  },
  "peerDependenciesMeta": {
    "solid-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "solid-js": "^1.9.5",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "vite-plugin-dts": "^4.5.0",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^4.1.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liamclarkza/snaplot.git"
  },
  "license": "MIT",
  "homepage": "https://liamclarkza.github.io/snaplot/",
  "bugs": {
    "url": "https://github.com/liamclarkza/snaplot/issues"
  },
  "keywords": [
    "solidjs",
    "chart",
    "canvas",
    "visualization",
    "dashboard",
    "heatmap",
    "scatter",
    "histogram",
    "line-chart",
    "bar-chart",
    "time-series",
    "plotting"
  ]
}
