{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "snaplot": ["../packages/snaplot/src/index.ts"],
      "snaplot/core": ["../packages/snaplot/src/core.ts"],
      "snaplot/solid": ["../packages/snaplot/src/solid.ts"]
    }
  },
  "include": ["src/**/*"]
}
