{
  "private": true,
  "workspaces": [
    "packages/*",
    "site"
  ],
  "scripts": {
    "build": "npm run build -w packages/snaplot",
    "dev": "npm run dev -w site --",
    "dev:host": "npm run dev -w site -- --host",
    "dev:lib": "npm run dev -w packages/snaplot",
    "build:site": "npm run build -w site",
    "preview": "npm run build && npm run build:site && npm run preview -w site",
    "typecheck": "npm run typecheck -w packages/snaplot",
    "test": "npm run test -w packages/snaplot",
    "test:watch": "npm run test:watch -w packages/snaplot",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "format": "biome format --write",
    "check": "biome check",
    "check:fix": "biome check --write",
    "prepare": "lefthook install || true"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "lefthook": "^2.1.6"
  }
}
